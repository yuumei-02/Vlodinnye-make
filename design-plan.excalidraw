    {
      "id": "X807x2KJb8SGX1aLT1PHo",
      "type": "text",
      "x": 1195.019932223258,
      "y": -41.8294303531959,
      "width": 607.1333618164062,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aF",
      "roundness": null,
      "seed": 1933802863,
      "version": 604,
      "versionNonce": 1160861281,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1777836454649,
      "link": null,
      "locked": false,
      "text": "There are two modes, major mode and minor mode.\nMinor mode are vim like modes that control keybindings\nlike for example visual mode for selection and insert mode\nfor text appending.\n\nMajor mode groups a selection on minor modes and controls\nhow and what other systems interact with the current buffer.\n\nFor example, you may have a C major mode that enables an\nC lsp",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "There are two modes, major mode and minor mode.\nMinor mode are vim like modes that control keybindings\nlike for example visual mode for selection and insert mode\nfor text appending.\n\nMajor mode groups a selection on minor modes and controls\nhow and what other systems interact with the current buffer.\n\nFor example, you may have a C major mode that enables an\nC lsp",
      "autoResize": true,
      "lineHeight": 1.25
    },
